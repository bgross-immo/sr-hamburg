<%- include('partials/header',{title}) %>
<h1><span class="pre">//</span> Kontakte</h1>
<div class="sub">Bespielte NSCs · Ort · Status · Historie</div>
<div class="grid cols3">
<% rows.forEach(x=>{ %>
  <a class="card" href="/connections/<%= x.slug %>">
    <% if(x.image){ var cs=x.image.indexOf('/static')===0?x.image:'/uploads/'+x.image; %><img class="thumb contain" src="<%= cs %>"><% } %>
    <div class="body">
      <h3><%= x.name %></h3>
      <div class="meta"><%= x.role %></div>
      <p><%= x.location %></p>
      <div style="margin-top:8px">
        <% if(x.influence){ %><span class="pill amber">Einfluss <%= x.influence %></span><% } %><% if(x.faction){ %><span class="pill green"><%= x.faction %></span><% } %>
        
      </div>
    </div>
  </a>
<% }); %>
</div>
<%- include('partials/footer') %>
