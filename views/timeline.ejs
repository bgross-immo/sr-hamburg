<%- include('partials/header',{title}) %>
<h1><span class="pre">//</span> Zeitleiste</h1>
<div class="sub">Alle Runs in der Reihenfolge, in der sie stattgefunden haben</div>
<div class="tl">
<% runs.forEach(r=>{ var when=runWhen(r); %>
  <div class="ev">
    <div class="when"><%= when || '— Datum offen —' %></div>
    <h3><a href="/runs/<%= r.slug %>" style="text-decoration:none;color:inherit"><%= r.number ? r.number+' · ' : '' %><%= r.title %></a></h3>
    <div class="dim" style="font-size:14px"><%= (r.summary||'').slice(0,180) %><%= (r.summary||'').length>180?'…':'' %></div>
    <div style="margin-top:4px"><a href="/runs/<%= r.slug %>">&rarr; im Logbuch</a></div>
  </div>
<% }); %>
</div>
<%- include('partials/footer') %>
