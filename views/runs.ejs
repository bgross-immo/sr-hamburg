<%- include('partials/header',{title}) %>
<h1><span class="pre">//</span> Logbuch</h1>
<div class="sub">Abgeschlossene Runs · Akten der Hamburger Runde</div>
<div class="grid cols2">
<% rows.forEach(r=>{ var imgs=JSON.parse(r.images||'[]'); %>
  <a class="card" href="/runs/<%= r.slug %>">
    <% if(imgs[0]){ %><img class="thumb" src="<%= imgs[0].indexOf('/static')===0?imgs[0]:'/uploads/'+imgs[0] %>"><% } %>
    <div class="body"><div class="meta"><%= r.number %> · <%= r.date_played||'' %></div><h3><%= r.title %></h3>
      <% if(r.participants){ %><div class="dim mono" style="font-size:11px;margin:2px 0"><%= r.participants %></div><% } %>
      <p><%= (r.summary||'').slice(0,150) %>…</p></div>
  </a>
<% }); %>
</div>
<% if(user.role==='sl'){ %>
<div class="panel" style="margin-top:18px"><div class="meta mono" style="color:var(--green)">SL · neuen Run anlegen</div>
  <p class="dim" style="font-size:13px;margin:6px 0 10px">Nur Spielleitung kann Runs anlegen. Du wirst Ersteller und darfst ihn danach bearbeiten. Details füllst du gleich im Editor.</p>
  <form method="post" action="/runs">
    <div class="row"><div style="flex:1"><label>Nummer</label><input name="number" placeholder="Run 3"></div><div style="flex:2"><label>Titel</label><input name="title"></div></div>
    <label>Teilnehmer</label><input name="participants">
    <div style="margin-top:12px"><button class="btn">Anlegen &amp; bearbeiten</button></div>
  </form></div>
<% } %>
<%- include('partials/footer') %>
