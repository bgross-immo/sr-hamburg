<%- include('partials/header',{title}) %>
<h1><span class="pre">//</span> Locations</h1>
<div class="sub">Bespielte Orte Hamburgs</div>
<div class="lvbar" data-listview="locations">
  <input class="lv-search" type="search" placeholder="Filtern (Name, Bereich, Typ)…">
  <select class="lv-sort">
    <option value="">Sortierung: Standard</option>
    <option value="name">Name A–Z</option>
    <option value="name:desc">Name Z–A</option>
    <option value="area">Bereich</option>
    <option value="type">Typ</option>
  </select>
  <span class="lvtoggle"><button data-view="grid">Kacheln</button><button data-view="list">Liste</button></span>
  <span class="lv-count"></span>
</div>
<div class="grid cols3" data-listgrid>
<% rows.forEach(l=>{ %>
  <a class="card" href="/locations/<%= l.slug %>"
     data-name="<%= l.name %>" data-area="<%= l.area||'' %>" data-type="<%= l.type||'' %>"
     data-search="<%= [l.name,l.area,l.type,l.status,l.description].filter(Boolean).join(' ') %>">
    <% if(l.image){ var ls=l.image.indexOf('/static')===0?l.image:'/uploads/'+l.image; %><img class="thumb contain" src="<%= ls %>"><% } %>
    <div class="body"><h3><%= l.name %></h3><div class="meta"><%= l.area||'' %></div>
      <div class="lcell"><% if(l.status){ %><span class="pill green"><%= l.status %></span><% } %></div>
      <p><%= l.description ? l.description.slice(0,110)+'…' : '' %></p></div>
  </a>
<% }); %>
</div>
<% if(user.role==='sl'){ %>
<div class="panel" style="margin-top:18px"><div class="meta mono" style="color:var(--green)">SL · Location hinzufügen</div>
  <form method="post" action="/sl/locations" class="row" style="margin-top:8px"><div style="flex:1"><input name="name" placeholder="Name der Location"></div><button class="btn">Anlegen</button></form>
</div>
<% } %>
<script src="/static/js/listview.js"></script>
<%- include('partials/footer') %>
