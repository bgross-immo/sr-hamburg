<%- include('partials/header',{title}) %>
<div class="dossier-tag">AKTE // <%= r.number %></div>
<h1 style="margin-top:4px"><%= r.title %></h1>
<div class="sub"><%= r.date_played || '' %></div>
<div class="panel kopf">
  <dl class="kv">
    <dt>Teilnehmer</dt><dd><%= r.participants||'—' %></dd>
    <dt>Ort</dt><dd><%= r.location||'—' %></dd>
  <% function fmtd(d){ if(!d) return ''; var p=String(d).split('-'); return p.length===3?p[2]+'.'+p[1]+'.'+p[0]:d; } var ws = r.date_start ? (fmtd(r.date_start)+(r.tod_start?' '+r.tod_start:'')+((r.date_end&&r.date_end!==r.date_start)?' – '+fmtd(r.date_end)+(r.tod_end?' '+r.tod_end:''):(r.tod_end&&r.tod_end!==r.tod_start?' – '+r.tod_end:''))) : ''; %>
    <% if(ws){ %><dt>Datum</dt><dd><%= ws %></dd><% } %>
    <dt>Zeitraum</dt><dd><%= [r.time_from,r.time_to].filter(Boolean).join('  –  ') || r.date_played || '—' %></dd>
    <dt>Karma</dt><dd><%= r.karma||'—' %></dd>
    <dt>Nuyen / Geld</dt><dd><%= r.nuyen||'—' %></dd>
    <dt>Beute</dt><dd><%= r.loot||'—' %></dd>
  </dl>
</div>
<% function pills(str, cls){ if(!str) return ''; return str.split(/[·,;]/).map(x=>x.trim()).filter(Boolean).map(x=>'<span class="pill '+cls+'">'+x.replace(/</g,'&lt;')+'</span>').join(''); } %>
<% if(r.actors){ %><h2>Beteiligte Akteure</h2><div class="pillrow"><%- pills(r.actors,'green') %></div><% } %>
<% function clink(arr, cls){ return (arr||[]).map(function(m){ return m.slug ? '<a class="pill '+cls+'" style="text-decoration:none" href="/connections/'+m.slug+'">'+m.name.replace(/</g,'&lt;')+'</a>' : '<span class="pill '+cls+'">'+m.name.replace(/</g,'&lt;')+'</span>'; }).join(''); } %>
<% if((involvedLinks&&involvedLinks.length) || (newLinks&&newLinks.length)){ %>
  <h2>Connections</h2><div class="pillrow"><%- clink(involvedLinks,'') %><%- clink(newLinks,'amber') %></div>
  <div class="dim mono" style="font-size:11px;margin-top:2px">grau = beteiligt · gelb = neu kennengelernt</div>
<% } %>
<h2>Bericht</h2>
<div class="panel"><div style="white-space:pre-line;font-size:14.5px"><%= r.summary %></div></div>
<% if(r.imageList.length){ %><h2>Bilder</h2><div class="gallery"><% r.imageList.forEach(i=>{ %><a href="<%= i.indexOf('/static')===0?i:'/uploads/'+i %>" target="_blank"><img src="<%= i.indexOf('/static')===0?i:'/uploads/'+i %>"></a><% }); %></div><% } %>
<div style="margin-top:22px;display:flex;gap:14px;align-items:center"><a href="/runs">&larr; Logbuch</a><% if(isOwner){ %><a class="btn ghost" href="/runs/<%= r.slug %>/edit">Bearbeiten</a><% } %></div>
<%- include('partials/footer') %>
