<%- include('partials/header',{title}) %>
<h1><span class="pre">//</span> <%= r.title %></h1>
<div class="sub"><%= r.number %> · <%= r.date_played %><% if(r.participants){ %> · <%= r.participants %><% } %></div>
<div class="panel"><div style="white-space:pre-line;font-size:14.5px"><%= r.summary %></div>
  <% if(r.imageList.length){ %><div class="gallery"><% r.imageList.forEach(i=>{ %><a href="/uploads/<%= i %>" target="_blank"><img src="/uploads/<%= i %>"></a><% }); %></div><% } %>
</div>
<% if(user.role==='sl'){ %>
<div class="panel"><div class="meta mono" style="color:var(--red)">SL · Run bearbeiten / Bilder</div>
  <form method="post" action="/sl/runs/<%= r.slug %>" enctype="multipart/form-data">
    <div class="row"><div style="flex:1"><label>Titel</label><input name="title" value="<%= r.title %>"></div><div style="flex:1"><label>Datum</label><input name="date_played" value="<%= r.date_played||'' %>"></div></div>
    <label>Teilnehmer</label><input name="participants" value="<%= r.participants||'' %>">
    <label>Zusammenfassung</label><textarea name="summary" rows="6"><%= r.summary %></textarea>
    <label>Bilder hinzufuegen</label><input type="file" name="images" accept="image/*" multiple>
    <div style="margin-top:12px"><button class="btn">Speichern</button></div>
  </form></div>
<% } %>
<p style="margin-top:14px"><a href="/runs">&larr; Logbuch</a></p>
<%- include('partials/footer') %>
