<!doctype html>
<html lang="de"><head>
<meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1">
<title><%= title %> // Schattennetz Hamburg</title>
<link rel="stylesheet" href="/static/css/style.css">
</head><body>
<div class="scan"></div>
<% if (user) { %>
<header class="top"><div class="wrap bar">
  <div class="brand"><b>SCHATTEN</b>NETZ<span class="dim"> // HAMBURG-KNOTEN</span> <span class="blink">_</span></div>
  <nav class="main">
    <% const nav=[['/','Knoten'],['/characters','Runner'],['/runs','Logbuch'],['/timeline','Zeitleiste'],['/connections','Kontakte'],['/notes','Notizen']];
       nav.forEach(n=>{ %><a href="<%= n[0] %>" class="<%= (n[0]==='/'? path==='/' : path.indexOf(n[0])===0)?'active':'' %>"><%= n[1] %></a><% }); %>
    <% if (user.role==='sl'){ %><a href="/sl" class="<%= path.indexOf('/sl')===0?'active':'' %>" style="color:var(--red)">SL // HDL</a><% } %>
  </nav>
  <div class="userbox"><span class="tag">@<%= user.username %></span><% if(user.role==='sl'){ %><span class="badge-sl">SL</span><% } %><a href="/account">Konto</a><a href="/logout">Logout</a></div>
</div></header>
<% } %>
<main><div class="wrap">
